# =====================================================================
# FRONTEND (Vite) — required for the app to load at all.
# Copy this file to `.env` in the project root and fill in real values,
# or the app will throw "Missing Supabase environment variables" on load.
# Get these from: Supabase Dashboard -> Project Settings -> API
# =====================================================================
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# =====================================================================
# RAZORPAY PAYMENT GATEWAY
# Frontend only exposes the KEY_ID (public, used by checkout.js)
# KEY_SECRET is strictly backend-only and set as Supabase secrets
# =====================================================================
VITE_RAZORPAY_KEY_ID=your-razorpay-key-id

# =====================================================================
# SUPABASE EDGE FUNCTIONS - SECRETS (DO NOT ADD HERE)
# These are NOT read by the Vite frontend — set them ONLY as Supabase
# Edge Function secrets in the dashboard, e.g.:
#   Supabase Dashboard → Edge Functions → Secrets
#   Add:
#     RAZORPAY_KEY_ID = rzp_live_TEcApCcyhTptHt
#     RAZORPAY_KEY_SECRET = your-secret
#
# SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY / SUPABASE_ANON_KEY are
# provided automatically by the Supabase Edge Runtime and don't need
# to be set manually.
# =====================================================================

# supabase/functions/send-email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@praxisgroup.online
SMTP_FROM_NAME=Praxis Group

# supabase/functions/send-email (Resend fallback, optional)
RESEND_API_KEY=
