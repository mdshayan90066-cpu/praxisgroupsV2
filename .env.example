# =====================================================================
# FRONTEND (Vite) — required for the app to load at all.
# Copy this file to `.env` in the project root and fill in real values,
# or the app will throw "Missing Supabase environment variables" on load.
# Get these from: Supabase Dashboard -> Project Settings -> API
# =====================================================================
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# =====================================================================
# SUPABASE EDGE FUNCTIONS
# These are NOT read by the Vite frontend — set them as Supabase
# Edge Function secrets instead, e.g.:
#   supabase secrets set RAZORPAY_KEY_ID=xxx RAZORPAY_KEY_SECRET=xxx
# SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY / SUPABASE_ANON_KEY are
# provided automatically by the Supabase Edge Runtime and don't need
# to be set manually.
# =====================================================================

# supabase/functions/razorpay-create-order
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# supabase/functions/razorpay-webhook
RAZORPAY_WEBHOOK_SECRET=

# supabase/functions/send-email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@praxisgroup.online
SMTP_FROM_NAME=Praxis Group

# supabase/functions/send-email (Resend fallback, optional)
RESEND_API_KEY=
